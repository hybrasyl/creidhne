{
  "name": "Creidhne",
  "version": "1.2.0",
  "description": "A bespoke XML editor for dreaming Hybrasyl worlds into reality",
  "main": "./out/main/index.js",
  "author": "Sabrael (http://www.github.com/Caeldeth)",
  "homepage": "https://github.com/hybrasyl/creidhne",
  "scripts": {
    "test": "vitest run",
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "lint:check": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "start": "electron-vite preview -- --trace-warnings",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:portable": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "fetch-xsd": "node scripts/downloadXSD.js",
    "convert-xsd": "node scripts/convertXsdToJson.js"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eriscorp/dalib-ts": "^1.0.1",
    "@eriscorp/hybindex-ts": "^0.2.0",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/cinzel-decorative": "^5.2.8",
    "@fontsource/crimson-pro": "^5.2.8",
    "@fontsource/eagle-lake": "^5.2.7",
    "@fontsource/yaldevi": "^5.2.9",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "fs-extra": "^11.3.4",
    "path": "^0.12.7",
    "react-icons": "^5.6.0",
    "react-image-filter": "^0.1.2",
    "react-window": "^2.2.7",
    "recoil": "^0.7.7",
    "unzipper": "^0.12.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.2",
    "xmllint-wasm": "^5.2.0"
  }
}
